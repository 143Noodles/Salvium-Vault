{
  "name": "salvium-vault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:android": "vite build && rm -f dist/salvium-vault.apk && npx cap sync android",
    "build:android:release": "bash scripts/build-android-release.sh",
    "build:android:fdroid": "bash scripts/build-android-fdroid-live.sh",
    "build:content-release": "node scripts/publish-content-release.mjs",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "preview": "vite preview",
    "start": "node server.cjs",
    "start:dev": "node --watch server.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:extension:chrome": "node scripts/build-extension.mjs chrome",
    "build:extension:firefox": "node scripts/build-extension.mjs firefox",
    "build:extensions": "npm run build:extension:chrome && npm run build:extension:firefox",
    "test:extension:headless": "node scripts/test-extension-headless.mjs",
    "verify:extensions": "npm run build:extensions && npm run test:extension:headless",
    "install:extension-browsers": "npx playwright install chromium firefox",
    "typecheck": "node scripts/typecheck-gate.mjs",
    "typecheck:update-baseline": "node scripts/typecheck-gate.mjs --update-baseline"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/status-bar": "^8.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "axios": "^1.18.1",
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "html5-qrcode": "^2.3.8",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.555.0",
    "node-fetch": "^2.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.3",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.9",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "esbuild": "0.28.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "jsdom": "^27.4.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.10",
    "selenium-webdriver": "^4.45.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/143Noodles/Salvium-Vault.git"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true
  }
}
