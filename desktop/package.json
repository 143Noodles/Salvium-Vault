{
  "name": "salvium-vault-desktop",
  "productName": "Salvium Vault",
  "version": "0.1.0",
  "description": "Salvium Vault Desktop Wallet",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:xvfb": "xvfb-run -a electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "io.salvium.vault.desktop",
    "productName": "Salvium Vault",
    "files": [
      "main.js",
      "content-update.js",
      "package.json",
      "build/icon.png",
      "preload.js",
      "afterPack.js"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "app",
        "filter": [
          "server.cjs",
          "dist/**",
          "node_modules/**",
          "wallet/**",
          "services/**",
          "server-csp-worker.cjs",
          "utils/**",
          "content-version.json"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "143Noodles",
        "repo": "Salvium-Vault-Web-Wallet"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "icon": "build/icon.png",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Finance",
      "icon": "build/icon.png",
      "desktop": {
        "Comment": "Salvium Vault Desktop Wallet"
      },
      "maintainer": "143Noodles <143Noodles@users.noreply.github.com>"
    },
    "directories": {
      "output": "release"
    },
    "afterPack": "afterPack.js",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Salvium Vault",
      "uninstallDisplayName": "Salvium Vault"
    }
  },
  "dependencies": {
    "tar": "^6.2.1"
  },
  "homepage": "https://salvium.io",
  "author": {
    "name": "Salvium",
    "email": "143Noodles@users.noreply.github.com"
  }
}
